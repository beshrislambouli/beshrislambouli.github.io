---
---
<style>
@media (max-width: 576px) {
  .entry-row { flex-direction:column !important; }
  .entry-logo { margin-right:0 !important; margin-bottom:0.75rem; justify-content:flex-start !important; }
}
</style>
<div class="entry-row" style="display:flex; align-items:flex-start; margin-bottom:1.5rem;">
  <!-- Thumbnail -->
  <div class="entry-logo" style="flex:0 0 120px; margin-right:1.25rem;">
    {% if entry.preview %}
      {% if entry.preview contains '://' %}
        <img src="{{ entry.preview }}" style="width:120px; border-radius:4px;">
      {% else %}
        <img src="{{ entry.preview | prepend: '/assets/img/' | relative_url }}" style="width:120px; border-radius:4px;">
      {% endif %}
    {% endif %}
  </div>

  <!-- Text -->
  <div style="flex:1;">
    <div style="font-weight:600;">
      {%- if entry.html -%}<a href="{{ entry.html }}" target="_blank">{{ entry.title }}</a>{%- else -%}{{ entry.title }}{%- endif -%}
    </div>

    <div style="color:#555; font-size:0.9em; margin-top:0.2rem;">
      {%- for author in entry.author_array -%}
        {%- assign author_last_html = author.last | replace: '*', '<sup>*</sup>' -%}
        {%- assign author_is_self = false -%}
        {%- if author.first == 'Beshr' -%}{%- assign author_is_self = true -%}{%- endif -%}
        {%- if forloop.first == false %}, {% endif -%}
        {%- if author_is_self -%}<u>{{ author.first }} {{ author_last_html }}</u>{%- else -%}{{ author.first }} {{ author_last_html }}{%- endif -%}
      {%- endfor -%}
    </div>

    <div style="color:#777; font-size:0.85em; margin-top:0.2rem; font-style:italic;">
      {%- if entry.type == 'article' -%}
        {{ entry.journal }}
      {%- elsif entry.type == 'inproceedings' or entry.type == 'incollection' -%}
        {{ entry.booktitle }}
      {%- elsif entry.type == 'thesis' or entry.type == 'phdthesis' or entry.type == 'mastersthesis' -%}
        {{ entry.school }}
      {%- endif -%}
      {%- if entry.year %} {{ entry.year }}{%- endif -%}
    </div>
  </div>
</div>
